# GLM Proxy Configuration

# Server port
PORT=3003

# Bind host (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
HOST=0.0.0.0

# API key for authenticating incoming requests (leave empty to disable auth)
API_KEY=

# Dashboard password (leave empty to disable dashboard auth)
DASHBOARD_PASSWORD=

# Default model to use when not specified in request
DEFAULT_MODEL=glm-4-flash

# Max tokens default
MAX_TOKENS=4096

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Data directory for accounts.json persistence
DATA_DIR=./data
